<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_black_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/backArrow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="@color/yellow_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Challenges"
                android:textSize="28sp"
                android:textColor="@color/pink_light"
                android:textStyle="bold"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 No spend challenge"
            android:textSize="26sp"
            android:textColor="@color/yellow_light"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:layout_gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose challenge length:"
            android:textSize="22sp"
            android:textColor="@color/yellow_light"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:layout_gravity="center" />

        <!-- Challenge Cards Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:weightSum="2">

            <Button
                android:id="@+id/btn3Days"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:text="3 days\n(Easy)"
                android:backgroundTint="@color/teal"
                android:textColor="@android:color/black"
                android:layout_marginEnd="8dp"
                android:padding="8dp" />

            <Button
                android:id="@+id/btn7Days"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:text="7 days\n(Medium)"
                android:backgroundTint="@color/orange"
                android:textColor="@android:color/black"
                android:layout_marginStart="8dp"
                android:padding="8dp" />

        </LinearLayout>

        <!-- 30 Days Button -->
        <Button
            android:id="@+id/btn30Days"
            android:layout_width="wrap_content"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:text="30 days\n(Hard Mode)"
            android:backgroundTint="@color/pink_dark"
            android:textColor="@android:color/white"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="32dp" />

        <!-- Current Challenge Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current challenge"
            android:textSize="24sp"
            android:textColor="@color/yellow_light"
            android:textStyle="bold"
            android:layout_marginTop="36dp"
            android:gravity="center"
            android:layout_gravity="center" />

        <!-- Day Counter Text -->
        <TextView
            android:id="@+id/tvCurrentDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 Day 3 of 7"
            android:textSize="22sp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:layout_gravity="center" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="250dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:progress="42"
            android:progressTint="@color/teal"
            android:layout_gravity="center" />

        <!-- Money Saved Text -->
        <TextView
            android:id="@+id/tvMoneySaved"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="R489 saved by not spending"
            android:textSize="20sp"
            android:textColor="@color/yellow_light"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:layout_gravity="center" />

        <!-- Start New Challenge Button -->
        <Button
            android:id="@+id/btnStartNew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start new challenge"
            android:backgroundTint="@color/gold_gradient"
            android:textColor="@android:color/black"
            android:layout_marginTop="36dp"
            android:paddingHorizontal="48dp"
            android:paddingVertical="16dp"
            android:layout_gravity="center" />

        <!-- Bottom Navigation Bar -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:menu="@menu/bottom_nav_menu"
            android:background="@color/purple_dark"
            app:itemIconTint="@color/yellow_light"
            app:itemTextColor="@color/yellow_light"
            app:labelVisibilityMode="labeled"
            app:itemTextAppearanceActive="@style/BottomNavText"
            app:itemTextAppearanceInactive="@style/BottomNavText"
            app:itemIconSize="32dp"/>
    </LinearLayout>
</ScrollView>